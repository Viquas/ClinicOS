# Supabase project — use the Mumbai (ap-south-1) region.
# DPDP Act 2023 makes India-region hosting the default posture for health data
# (PRD §9.1), and moving regions later means migrating live patient records.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Bypasses RLS. Server-only — never expose to the browser, never prefix with
# NEXT_PUBLIC_. Used by background workers and the onboarding wizard, which run
# without a user session.
SUPABASE_SERVICE_ROLE_KEY=

# Pooled connection string for Drizzle (Supabase: Settings > Database >
# Connection pooling, transaction mode).
DATABASE_URL=

# WhatsApp Cloud API (PRD §7.10)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
